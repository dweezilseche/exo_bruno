## Architecture des modules

### main.js — Orchestrateur

```javascript
import { initSmoothScroll } from "./smooth-scroll.js";
import { initAnimations } from "./animations.js";
import { initTextSplit } from "./text-split.js";
import { initSliders } from "./slider.js";

document.addEventListener("DOMContentLoaded", () => {
  initSmoothScroll();
  initTextSplit();
  initAnimations();
  initSliders();
});
```

### smooth-scroll.js — Lenis + GSAP

```javascript
export function initSmoothScroll() {
  const lenis = new Lenis({
    lerp: 0.1,
    smooth: true,
  });

  // Connecter Lenis à GSAP ScrollTrigger
  lenis.on("scroll", ScrollTrigger.update);
  gsap.ticker.add((time) => {
    lenis.raf(time * 1000);
  });
  gsap.ticker.lagSmoothing(0);
}
```

### animations.js — GSAP ScrollTrigger

```javascript
export function initAnimations() {
  gsap.registerPlugin(ScrollTrigger);

  // Fade up
  document.querySelectorAll("[data-animate='fade-up']").forEach((el) => {
    const delay = parseFloat(el.getAttribute("data-animate-delay")) || 0;
    gsap.from(el, {
      y: 60,
      opacity: 0,
      duration: 1,
      delay,
      ease: "power3.out",
      scrollTrigger: {
        trigger: el,
        start: "top 85%",
        toggleActions: "play none none none",
      },
    });
  });

  // Ajouter ici les autres types d'animation (fade-in, fade-left, scale-in...)
}
```

### text-split.js — SplitType + GSAP

```javascript
export function initTextSplit() {
  // Split par caractères
  document.querySelectorAll("[data-split='chars']").forEach((el) => {
    const split = new SplitType(el, { types: "chars" });
    gsap.from(split.chars, {
      y: 40,
      opacity: 0,
      duration: 0.6,
      stagger: 0.03,
      ease: "power3.out",
      scrollTrigger: {
        trigger: el,
        start: "top 85%",
        toggleActions: "play none none none",
      },
    });
  });

  // Ajouter ici split par words, lines...
}
```

### slider.js — Swiper

```javascript
export function initSliders() {
  // Slider témoignages
  const testimonialEl = document.querySelector("[data-slider='testimonials']");
  if (testimonialEl) {
    new Swiper(testimonialEl, {
      slidesPerView: 1,
      spaceBetween: 24,
      loop: true,
      autoplay: { delay: 4000, disableOnInteraction: false },
      pagination: {
        el: testimonialEl.querySelector(".swiper-pagination"),
        clickable: true,
      },
      breakpoints: {
        768: { slidesPerView: 2 },
        1024: { slidesPerView: 3 },
      },
    });
  }

  // Ajouter ici d'autres sliders...
}
```

